{
  "model": [
    {
      "bundle": "homepage",
      "label": "Homepage",
      "description": "Blog landing page with hero, stats, and featured content",
      "fields": [
        { "id": "hero_title", "label": "Hero Title", "type": "string" },
        { "id": "hero_subtitle", "label": "Hero Subtitle", "type": "string" },
        { "id": "hero_description", "label": "Hero Description", "type": "text" },
        { "id": "hero_image", "label": "Hero Image", "type": "image" },
        { "id": "stats_items", "label": "Statistics", "type": "paragraph(stat_item)[]" },
        { "id": "featured_items_title", "label": "Featured Posts Title", "type": "string" },
        { "id": "cta_title", "label": "CTA Title", "type": "string" },
        { "id": "cta_description", "label": "CTA Description", "type": "text" },
        { "id": "cta_primary", "label": "Primary CTA", "type": "string" },
        { "id": "cta_secondary", "label": "Secondary CTA", "type": "string" }
      ]
    },
    {
      "bundle": "post",
      "label": "Post",
      "description": "A blog post with subscription tier gating",
      "body": true,
      "fields": [
        { "id": "post_image", "label": "Featured Image", "type": "image" },
        { "id": "excerpt", "label": "Excerpt", "type": "text" },
        { "id": "author_name", "label": "Author Name", "type": "string" },
        { "id": "author_photo", "label": "Author Photo", "type": "image" },
        { "id": "read_time", "label": "Read Time", "type": "string" },
        { "id": "subscription_tier", "label": "Subscription Tier", "type": "string" },
        { "id": "featured", "label": "Featured", "type": "bool" },
        { "id": "tags", "label": "Tags", "type": "term(tags)[]" }
      ]
    },
    {
      "bundle": "page",
      "label": "Basic Page",
      "description": "Static content pages for about, contact, privacy, etc.",
      "body": true,
      "fields": []
    },
    {
      "entity": "paragraph",
      "bundle": "stat_item",
      "label": "Statistic Item",
      "fields": [
        { "id": "number", "label": "Number", "type": "string!" },
        { "id": "label", "label": "Label", "type": "string!" }
      ]
    }
  ],
  "taxonomies": [
    {
      "vocabulary": "tags",
      "label": "Tags",
      "terms": ["drupal", "headless-cms", "nextjs", "graphql", "tutorial", "architecture", "content-modeling", "migration"]
    }
  ],
  "content": [
    {
      "id": "stat-posts",
      "type": "paragraph.stat_item",
      "values": { "number": "80+", "label": "Tutorials Published" }
    },
    {
      "id": "stat-subscribers",
      "type": "paragraph.stat_item",
      "values": { "number": "3,200", "label": "Subscribers" }
    },
    {
      "id": "stat-reads",
      "type": "paragraph.stat_item",
      "values": { "number": "500K+", "label": "Total Reads" }
    },
    {
      "id": "stat-years",
      "type": "paragraph.stat_item",
      "values": { "number": "3", "label": "Years Running" }
    },
    {
      "id": "homepage",
      "type": "node.homepage",
      "path": "/homepage",
      "values": {
        "title": "Decoupled Drupal Blog",
        "hero_title": "Decoupled Drupal",
        "hero_subtitle": "Practical guides for building headless CMS architectures with Drupal",
        "hero_description": "<p>Deep dives into headless Drupal, decoupled CMS architecture, and modern frontend integration. Practical tutorials and real-world strategies for teams building with Drupal's API-first approach.</p>",
        "hero_image": {
          "uri": "https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=800&q=80",
          "alt": "Modern content management dashboard"
        },
        "stats_items": ["@stat-posts", "@stat-subscribers", "@stat-reads", "@stat-years"],
        "featured_items_title": "Featured Guides",
        "cta_title": "Subscribe for Premium Tutorials",
        "cta_description": "<p>Get access to in-depth Drupal decoupling tutorials, architecture deep dives, and members-only implementation guides.</p>",
        "cta_primary": "Subscribe - $9/month",
        "cta_secondary": "Free Newsletter"
      }
    },
    {
      "id": "post-1",
      "type": "node.post",
      "path": "/posts/why-headless-drupal-future-cms",
      "values": {
        "title": "Why Headless Drupal Is the Future of Content Management",
        "body": "<p>The monolithic CMS is fading. Organizations that once relied on tightly coupled themes and server-rendered pages are discovering that a headless Drupal architecture unlocks speed, flexibility, and developer experience that traditional setups simply cannot match.</p>",
        "post_image": {
          "uri": "https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=800&q=80",
          "alt": "Modern web dashboard"
        },
        "excerpt": "<p>Discover why headless Drupal is becoming the architecture of choice for teams that want speed, flexibility, and modern developer experience.</p>",
        "author_name": "Alex Rivera",
        "author_photo": {
          "uri": "https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?w=800&q=80",
          "alt": "Alex Rivera"
        },
        "read_time": "10 min read",
        "subscription_tier": "free",
        "featured": true,
        "tags": ["headless-cms", "drupal"]
      }
    },
    {
      "id": "post-2",
      "type": "node.post",
      "path": "/posts/decoupled-drupal-nextjs-guide",
      "values": {
        "title": "Building a Decoupled CMS with Drupal and Next.js: A Step-by-Step Guide",
        "body": "<p>Pairing Drupal's powerful content modeling with Next.js's rendering capabilities creates one of the most capable web stacks available today.</p>",
        "post_image": {
          "uri": "https://images.unsplash.com/photo-1555066931-4365d14bab8c?w=800&q=80",
          "alt": "Code editor showing Next.js"
        },
        "excerpt": "<p>A complete walkthrough for building a production-ready decoupled CMS with Drupal and Next.js.</p>",
        "author_name": "Alex Rivera",
        "author_photo": {
          "uri": "https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?w=800&q=80",
          "alt": "Alex Rivera"
        },
        "read_time": "18 min read",
        "subscription_tier": "premium",
        "featured": true,
        "tags": ["tutorial", "nextjs", "drupal"]
      }
    },
    {
      "id": "post-3",
      "type": "node.post",
      "path": "/posts/graphql-vs-jsonapi-drupal",
      "values": {
        "title": "GraphQL vs JSON:API for Headless Drupal: Choosing the Right API Layer",
        "body": "<p>When decoupling Drupal, one of the first decisions you will face is which API format to use.</p>",
        "post_image": {
          "uri": "https://images.unsplash.com/photo-1558494949-ef010cbdcc31?w=800&q=80",
          "alt": "Abstract network connections"
        },
        "excerpt": "<p>A practical comparison of JSON:API and GraphQL for headless Drupal architectures.</p>",
        "author_name": "Samira Patel",
        "author_photo": {
          "uri": "https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=800&q=80",
          "alt": "Samira Patel"
        },
        "read_time": "12 min read",
        "subscription_tier": "free",
        "featured": false,
        "tags": ["graphql", "drupal"]
      }
    },
    {
      "id": "post-4",
      "type": "node.post",
      "path": "/posts/content-modeling-decoupled-drupal",
      "values": {
        "title": "Content Modeling Best Practices for Decoupled Drupal",
        "body": "<p>Content modeling is the foundation of any CMS project, but it becomes even more critical in a decoupled architecture.</p>",
        "post_image": {
          "uri": "https://images.unsplash.com/photo-1552664730-d307ca884978?w=800&q=80",
          "alt": "Team collaborating on architecture"
        },
        "excerpt": "<p>Learn best practices for structuring Drupal content types, paragraphs, and taxonomies for headless delivery.</p>",
        "author_name": "Samira Patel",
        "author_photo": {
          "uri": "https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=800&q=80",
          "alt": "Samira Patel"
        },
        "read_time": "14 min read",
        "subscription_tier": "premium",
        "featured": false,
        "tags": ["content-modeling", "drupal"]
      }
    },
    {
      "id": "post-5",
      "type": "node.post",
      "path": "/posts/migrating-monolithic-to-headless",
      "values": {
        "title": "Migrating from Monolithic Drupal to a Headless Architecture",
        "body": "<p>You have a production Drupal site with years of content. Now leadership wants a modern frontend. Here is the incremental strategy.</p>",
        "post_image": {
          "uri": "https://images.unsplash.com/photo-1544383835-bda2bc66a55d?w=800&q=80",
          "alt": "Architecture diagram"
        },
        "excerpt": "<p>A practical, incremental strategy for migrating from monolithic Drupal to headless.</p>",
        "author_name": "Alex Rivera",
        "author_photo": {
          "uri": "https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?w=800&q=80",
          "alt": "Alex Rivera"
        },
        "read_time": "15 min read",
        "subscription_tier": "free",
        "featured": false,
        "tags": ["migration", "drupal", "architecture"]
      }
    },
    {
      "id": "page-about",
      "type": "node.page",
      "path": "/posts",
      "values": {
        "title": "About Decoupled Drupal Blog",
        "body": "<p>Decoupled Drupal Blog is a resource for developers and architects building headless CMS solutions with Drupal.</p>"
      }
    },
    {
      "id": "page-privacy",
      "type": "node.page",
      "path": "/privacy",
      "values": {
        "title": "Privacy Policy",
        "body": "<p>Decoupled Drupal Blog respects your privacy. This policy explains what data we collect, how we use it, and your rights.</p>"
